# Local dev without Docker — points directly at the backend
VITE_PROXY_HOST=http://localhost:8000
VITE_API_BASE=/api

# Docker dev — set automatically by docker-compose.yml (no .env needed)
# VITE_API_BASE=/fastapi
# VITE_PROXY_HOST=http://fastapi:8000

# Optional API key (leave blank if not used)
VITE_X_API_KEY=
